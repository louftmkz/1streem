# Kopiere diese Datei zu .env.local (lokal) oder setze die Variablen in
# Vercel → Settings → Environment Variables.
#
# Wenn weder Backend noch manuelle Vars gesetzt sind, zeigt das Dashboard "—".
# Keine Mock-Zahlen.

# --- Phase 2 (Backend-Scraper, sobald deployed) ---
# Wenn gesetzt, hat es Vorrang vor den manuellen Vars.
VITE_BACKEND_URL=

# --- Phase 1 (Manuelle Eingabe aus Spotify for Artists) ---
VITE_ARTIST_NAME=Lou FTMKZ
VITE_TOTAL_STREAMS=
VITE_SONG_COUNT=
VITE_STATS_AS_OF=
# Top 10 als JSON-Array. Reihenfolge = absteigend nach Streams.
VITE_TOP_TRACKS_JSON=[]
